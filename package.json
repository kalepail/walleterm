{
  "name": "walleterm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "walleterm": "src/cli.ts"
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "typecheck": "bun x tsc -p tsconfig.json",
    "build": "bun run typecheck && bun run bundle",
    "compile": "bun build ./src/cli.ts --compile --outfile=dist/walleterm --target=bun",
    "bundle": "node ./node_modules/rolldown/bin/cli.mjs -c rolldown.config.mjs",
    "lint": "bun x oxlint --config .oxlintrc.json --deny-warnings src tests",
    "lint:fix": "bun x oxlint --config .oxlintrc.json --fix src tests",
    "format": "bun x oxfmt --config .oxfmtrc.json --write src tests",
    "format:check": "bun x oxfmt --config .oxfmtrc.json --check src tests",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "test": "bun x vitest run",
    "test:watch": "bun x vitest",
    "coverage": "bun x vitest run --coverage",
    "test:live": "WALLETERM_LIVE=1 bun x vitest run --coverage=false tests/live/wallet-live.test.ts",
    "test:live:op": "WALLETERM_LIVE=1 WALLETERM_LIVE_OP=1 bun x vitest run --coverage=false tests/live/op-live.test.ts",
    "test:live:all": "WALLETERM_LIVE=1 WALLETERM_LIVE_OP=1 bun x vitest run --coverage=false",
    "install:ci": "bun install --frozen-lockfile"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@openzeppelin/relayer-plugin-channels": "^0.16.0",
    "@stellar/stellar-sdk": "^14.6.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "execa": "^9.6.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rolldown": "^1.0.0-rc.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
